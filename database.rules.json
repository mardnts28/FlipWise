{
  "rules": {
    ".read": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() == 'admin'",
    ".write": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() == 'admin'",
    "users": {
      "$uid": {
        ".read": "auth != null && auth.uid == $uid",
        ".write": "auth != null && auth.uid == $uid",
        "friends": {
          "$friendId": {
            ".write": "auth != null && (auth.uid == $uid || (auth.uid == $friendId && (!newData.exists() || newData.child('status').val() == 'pending' || (data.exists() && newData.child('status').val() == 'accepted'))))",
            ".validate": "newData.hasChildren(['id', 'userId', 'username', 'displayName', 'status'])"
          }
        },
        "notifications": {
          "$notificationId": {
            ".write": "auth != null && (auth.uid == $uid || (newData.exists() && (newData.child('type').val() == 'friend_accepted' || newData.child('type').val() == 'friend_declined')))"
          }
        }
      }
    },
    "leaderboard": {
      ".read": "auth != null",
      ".indexOn": [
        "username",
        "totalPoints"
      ],
      "$uid": {
        // Only server (Admin SDK) should write to leaderboard to prevent point tampering
        ".write": "false"
      }
    },
    "challenges": {
      ".read": "auth != null",
      "$challengeId": {
        "participants": {
          "$uid": {
            ".write": "auth != null && auth.uid == $uid",
            ".validate": "newData.hasChildren(['userId', 'score'])"
          }
        }
      }
    },
    "community_decks": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() == 'admin'"
    },
    "audit_logs": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() == 'admin'",
      "$logId": {
        // Users can push logs but never read or overwrite them
        ".write": "auth != null && !data.exists()",
        ".validate": "newData.hasChildren(['userId', 'action', 'timestamp'])"
      }
    },
    "public_announcements": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('profile').child('role').val() == 'admin'"
    }
  }
}