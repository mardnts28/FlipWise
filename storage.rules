rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper to check if user is admin
    function isAdmin() {
      return request.auth != null && 
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Secure rule for study documents
    match /study_documents/{userId}/{fileName} {
      // Users can only read/write their own documents
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Admins can audit any document
      allow read: if isAdmin();
      
      // Limit file size to 10MB during upload
      allow write: if request.resource.size < 10 * 1024 * 1024;
    }

    // Public assets (e.g. deck icons) - read only for everyone
    match /public_assets/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Default: Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
